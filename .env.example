# .env.example - Copy to .jirarc or .env and fill in your values
# Rename to .jirarc for project-level config, or ~/.jirarc for global config.
# Variables already set in the environment take precedence over this file.

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# Base URL of your Jira instance
# Cloud:  https://yoursite.atlassian.net
# Server: https://jira.yourcompany.com
JIRA_URL=https://yoursite.atlassian.net

# Cloud: your Atlassian account email
JIRA_EMAIL=you@example.com

# Cloud: API token from https://id.atlassian.com/manage-profile/security/api-tokens
# Server: API token (PAT) or leave blank and set JIRA_PASSWORD instead
JIRA_TOKEN=your_api_token_here

# ---------------------------------------------------------------------------
# Server / Data Center only
# ---------------------------------------------------------------------------

# JIRA_TYPE=server
# JIRA_USERNAME=youruser
# JIRA_PASSWORD=yourpassword   # only if not using JIRA_TOKEN

# ---------------------------------------------------------------------------
# Auth (optional — defaults are usually correct)
# ---------------------------------------------------------------------------

# basic (default for Cloud + Server) or bearer (for PAT-only Server auth)
# JIRA_AUTH_TYPE=basic

# ---------------------------------------------------------------------------
# Export defaults (all overridable via CLI flags)
# ---------------------------------------------------------------------------

# Output format: md (default), html, or raw
# JIRA_FORMAT=md

# Output directory (default: ./export)
# JIRA_OUTPUT_DIR=./export

# Overwrite existing files: 0 (default) or 1
# JIRA_FORCE=0

# Issues per API page (default: 50, max: 100)
# JIRA_SEARCH_PAGE_SIZE=50

# ---------------------------------------------------------------------------
# Reliability
# ---------------------------------------------------------------------------

# Number of retries on transient errors (default: 3)
# JIRA_MAX_RETRIES=3

# Seconds to wait between retries, doubles on each attempt (default: 5)
# JIRA_RETRY_DELAY=5

# ---------------------------------------------------------------------------
# Debugging
# ---------------------------------------------------------------------------

# Set to 1 to enable verbose debug output to stderr
# JIRA_DEBUG=0
